# ==========================
# HOTSPOT MANAGER - ENV
# ==========================

# Servidor
NODE_ENV=production
PORT=3000

# Base de datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hotspot_manager
DB_USER=hotspot_user
DB_PASSWORD=your_secure_password_here

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=your_refresh_secret_key
JWT_REFRESH_EXPIRES_IN=7d

# MikroTik (defaults, se puede sobreescribir por dispositivo)
MIKROTIK_TIMEOUT=5000
MIKROTIK_KEEPALIVE=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Logs
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Sincronización automática (cron)
SYNC_INTERVAL_MINUTES=5

# CORS - dominios permitidos
CORS_ORIGINS=http://localhost:3001,https://tu-dominio.com

# Admin inicial (para seed)
ADMIN_EMAIL=admin@tudominio.com
ADMIN_PASSWORD=Admin@12345!
ADMIN_NAME=Administrador
