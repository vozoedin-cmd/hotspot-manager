# ──────────────────────────────────────────────────────
#  Hotspot Manager — Backend — Variables de entorno
#  Copia a .env y edita TODOS los valores marcados con ⚠️
#    cp .env.example .env
# ──────────────────────────────────────────────────────

# ── Servidor ──────────────────────────────────────────
NODE_ENV=production          # production | development | test
PORT=3000

# ── Base de datos PostgreSQL ──────────────────────────
DB_HOST=db                   # Nombre servicio Docker; usa 'localhost' en dev
DB_PORT=5432
DB_NAME=hotspot_db
DB_USER=hotspot_user
DB_PASS=CAMBIA_ESTO          # ⚠️  openssl rand -hex 16

# ── JWT ───────────────────────────────────────────────
JWT_SECRET=CAMBIA_ESTO       # ⚠️  openssl rand -hex 32  (mín. 32 chars)
JWT_REFRESH_SECRET=CAMBIA    # ⚠️  openssl rand -hex 32
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────
# Producción: especifica el dominio exacto (sin *)
# Múltiples: https://dominio.com,https://app.dominio.com
CORS_ORIGINS=http://localhost:3001

# ── Rate Limiting ─────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000  # 15 min en ms
RATE_LIMIT_MAX=100           # Máx. requests globales por ventana

# ── Admin inicial (seed.js) ───────────────────────────
ADMIN_NAME=Administrador
ADMIN_EMAIL=admin@tu-dominio.com  # ⚠️  Cambia antes del primer seed
ADMIN_PASSWORD=CAMBIA_ESTO        # ⚠️  Contraseña segura

# ── Sincronización MikroTik ───────────────────────────
SYNC_INTERVAL_MINUTES=5      # Minutos entre sincronizaciones de routers
MIKROTIK_TIMEOUT=10000       # Timeout conexión RouterOS en ms

# ── Logs ──────────────────────────────────────────────
LOG_LEVEL=info               # error | warn | info | http | debug

# ── Backups ───────────────────────────────────────────
BACKUP_KEEP_DAYS=7           # Días a conservar copias de seguridad de BD
